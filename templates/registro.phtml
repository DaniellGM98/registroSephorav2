<body>
<div class="container">
    <h1>CONSULTA TUS SELLOS</h1>
    <h2>Escanea el Código QR</h2>
    <div class="sub"></div>

    <div class="scan-area">
        <div class="input-group">
            <label>Código QR / Pulsera</label>
            <input type="text" id="qrInput" placeholder="Coloque el código QR frente al lector..." autofocus>
        </div>
    </div>

    <div id="resultContainer" class="result-area hidden">
        <div id="resultContent"></div>
    </div>
    <div class="footer">
        Los resultados se mostrarán por 6 segundos y se reiniciará la pantalla.
    </div>
    <div class="footer2">
        "Si eres parte de Sephora Rewards, en compras superiores a $2,000 llévate una mini bag"<br>
        Sujeto a disponibilidad.<br> Consulta TyC en https://www.sephora.com.mx/pages/terms.html
    </div>
</div>

<script>
    // URL base de la API
    const API_BASE_URL = '<?= API_ROOT ?>';
    
    // Variables globales
    let timeoutReset = null;
    let isProcessing = false;
    const qrInput = document.getElementById('qrInput');
    const resultContainer = document.getElementById('resultContainer');
    const resultContent = document.getElementById('resultContent');

    function clearResetTimer() {
        if (timeoutReset) {
            clearTimeout(timeoutReset);
            timeoutReset = null;
        }
    }

    function resetToOriginal() {
        resultContainer.classList.add('hidden');
        resultContent.innerHTML = '';
        qrInput.value = '';
        qrInput.disabled = false;
        isProcessing = false;
        clearResetTimer();
        qrInput.focus();
    }

    function showError(message) {
        resultContent.innerHTML = `<div class="error-message">⚠️ ${message}</div>`;
        resultContainer.classList.remove('hidden');
        clearResetTimer();
        // Error: 3 segundos
        timeoutReset = setTimeout(() => resetToOriginal(), 3000);
    }

    function showLoading() {
        resultContent.innerHTML = `<div class="loading"><div class="spinner"></div><span>Consultando datos...</span></div>`;
        resultContainer.classList.remove('hidden');
    }

    // Función para obtener la meta del premio (número de stands necesarios)
    async function obtenerMetaPremio() {
        try {
            const url = `${API_BASE_URL}registro/getVariable/premio`;
            const response = await fetch(url, {
                method: 'GET',
                headers: { 'Accept': 'application/json' }
            });
            if (!response.ok) throw new Error(`HTTP ${response.status}`);
            const data = await response.json();
            if (data && data.response === true && data.result) {
                const meta = parseInt(data.result, 10);
                return isNaN(meta) ? 0 : meta;
            }
            return 0;
        } catch (error) {
            console.error('Error al obtener la meta del premio:', error);
            return 0;
        }
    }

    // Función para mostrar resultados y progreso
    async function displayResults(dataArray) {
        if (!dataArray || dataArray.length === 0) {
            showError("No se encontraron registros para este código QR.");
            return;
        }

        // 1. Contar stands visitados (con fecha_entrada y fecha_salida)
        const standsVisitados = dataArray.filter(item => 
            item['fecha_entrada'] && item['fecha_salida']
        ).length;

        // 2. Obtener la meta total desde la API
        const totalStandsRequeridos = await obtenerMetaPremio();
        
        // 3. Calcular los que faltan
        const standsFaltantes = Math.max(0, totalStandsRequeridos - standsVisitados);
        const porcentaje = totalStandsRequeridos > 0 
            ? (standsVisitados / totalStandsRequeridos) * 100 
            : 0;

        // 4. Verificar si cumple o supera la meta
        const cumplePremio = (standsVisitados >= totalStandsRequeridos) && (totalStandsRequeridos > 0);
        
        // 5. Construir el HTML del progreso
        let htmlProgreso = `
            <div class="progress-container">
                <div class="progress-title">PROGRESO</div>
                <div class="progress-stats">
                    <div class="stat-card">
                        <div class="stat-label">REALIZADOS</div>
                        <div class="stat-number">${standsVisitados}</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">REQUERIDOS</div>
                        <div class="stat-number">${totalStandsRequeridos}</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">PENDIENTES</div>
                        <div class="stat-number">${standsFaltantes}</div>
                    </div>
                </div>
                <div class="progress-bar-bg">
                    <div class="progress-bar-fill" style="width: ${porcentaje}%;"></div>
                </div>
        `;
        
        // Mensaje condicional
        if (cumplePremio) {
            htmlProgreso += `
                <div class="premio-message">
                    🎉 ¡Felicidades!<br> Has alcanzado el Número de sellos
                </div>
            `;
        } else if (totalStandsRequeridos > 0) {
            htmlProgreso += `
                <div class="faltante-message">
                    Te falta realizar ${standsFaltantes} Actividad${standsFaltantes !== 1 ? 'es' : ''}
                </div>
            `;
        }
        
        htmlProgreso += `</div>`; // cierre del progress-container

        // 6. Construir el HTML de los registros individuales (tarjetas)
        let htmlRegistros = '';
        for (const item of dataArray) {
            const nombre = escapeHtml(item['nombre'] || 'Sin nombre');
            const tieneSalida = item['fecha_salida'] && item['fecha_salida'] !== null && item['fecha_salida'] !== '';
            
            // Clase condicional: si NO tiene salida, agregar clase 'pending-card'
            const cardClass = !tieneSalida ? 'result-card result-card-pending' : 'result-card';
            
            htmlRegistros += `
                <div class="${cardClass}">
                    <div class="result-nombre">${nombre}</div>
                </div>
            `;
        }

        // Envolver las tarjetas en un grid de dos columnas (solo si hay tarjetas)
        let htmlRegistrosGrid = '';
        if (htmlRegistros) {
            htmlRegistrosGrid = `<div class="cards-grid">${htmlRegistros}</div>`;
        }

        // Combinar progreso y tarjetas en grid
        resultContent.innerHTML = htmlProgreso + htmlRegistrosGrid;
        resultContainer.classList.remove('hidden');

        clearResetTimer();
        // Resultados exitosos: 6 segundos (ajustado a 6000 ms)
        timeoutReset = setTimeout(() => resetToOriginal(), 6000);
    }

    function escapeHtml(str) {
        if (!str) return '';
        return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }

    async function consultarQR(codigo) {
        if (!codigo || codigo.trim() === '') {
            showError('El código QR está vacío. Escanea nuevamente.');
            return;
        }

        if (isProcessing) {
            clearResetTimer();
            resetToOriginal();
            setTimeout(() => consultarQR(codigo), 100);
            return;
        }

        isProcessing = true;
        qrInput.disabled = true;
        showLoading();

        try {
            const url = `${API_BASE_URL}registro/getAllByCodigo/${encodeURIComponent(codigo)}`;
            const response = await fetch(url, {
                method: 'GET',
                headers: {
                    'Accept': 'application/json',
                    'Content-Type': 'application/json'
                }
            });

            if (!response.ok) {
                throw new Error(`HTTP ${response.status}`);
            }

            const data = await response.json();

            if (data && data.response === true && Array.isArray(data.result)) {
                await displayResults(data.result);
            } else if (data && data.response === false) {
                showError(data.message || 'La API respondió con error. Código no válido.');
            } else {
                showError('Formato de respuesta inesperado.');
            }
        } catch (error) {
            console.error('Error en la consulta:', error);
            showError('Error de conexión con el servidor. Verifica tu red.');
        } finally {
            if (!timeoutReset) {
                setTimeout(() => {
                    if (isProcessing) resetToOriginal();
                }, 3000); // margen extra
            }
        }
    }

    // Evento Enter en el input
    qrInput.addEventListener('keypress', (event) => {
        if (event.key === 'Enter') {
            event.preventDefault();
            const codigo = qrInput.value.trim();
            if (codigo !== '') {
                consultarQR(codigo);
            } else {
                showError('Escanee un código QR válido.');
            }
        }
    });

    // Botón manual de consulta
    const addManualButton = () => {
        const btn = document.createElement('button');
        btn.textContent = 'Consultar código';
        btn.style.display = 'block';
        btn.style.margin = '1rem auto 0';
        btn.onclick = () => {
            const codigo = qrInput.value.trim();
            if (codigo) consultarQR(codigo);
            else showError('Escribe un código primero');
        };
        document.querySelector('.scan-area').appendChild(btn);
    };
    addManualButton();

    // Mantener el foco en el input
    qrInput.focus();
    document.body.addEventListener('click', () => qrInput.focus());
</script>
</body>
</html>